<?xml version="1.0"?>
<robot name="trident_drone">

  <!-- ==================== -->
  <!-- LINKS                -->
  <!-- ==================== -->

  <link name="base_link">
    <visual>
      <geometry><box size="0.3 0.3 0.1"/></geometry>
      <material name="dark_grey">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
    <collision>
      <geometry><box size="0.3 0.3 0.1"/></geometry>
    </collision>
    <inertial>
      <mass value="1.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0"
               iyy="0.01" iyz="0" izz="0.02"/>
    </inertial>
  </link>

  <link name="arm_fl">
    <visual>
      <geometry><box size="0.15 0.03 0.02"/></geometry>
      <material name="grey"><color rgba="0.4 0.4 0.4 1"/></material>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <link name="arm_fr">
    <visual>
      <geometry><box size="0.15 0.03 0.02"/></geometry>
      <material name="grey"><color rgba="0.4 0.4 0.4 1"/></material>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <link name="arm_bl">
    <visual>
      <geometry><box size="0.15 0.03 0.02"/></geometry>
      <material name="grey"><color rgba="0.4 0.4 0.4 1"/></material>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <link name="arm_br">
    <visual>
      <geometry><box size="0.15 0.03 0.02"/></geometry>
      <material name="grey"><color rgba="0.4 0.4 0.4 1"/></material>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <link name="rotor_fl">
    <visual>
      <geometry><cylinder radius="0.1" length="0.01"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0" izz="0.0002"/>
    </inertial>
  </link>

  <link name="rotor_fr">
    <visual>
      <geometry><cylinder radius="0.1" length="0.01"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0" izz="0.0002"/>
    </inertial>
  </link>

  <link name="rotor_bl">
    <visual>
      <geometry><cylinder radius="0.1" length="0.01"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0" izz="0.0002"/>
    </inertial>
  </link>

  <link name="rotor_br">
    <visual>
      <geometry><cylinder radius="0.1" length="0.01"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0" izz="0.0002"/>
    </inertial>
  </link>

  <link name="rgb_camera_link">
    <visual>
      <geometry><box size="0.04 0.04 0.03"/></geometry>
      <material name="red"><color rgba="0.8 0.1 0.1 1"/></material>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <link name="thermal_camera_link">
    <visual>
      <geometry><box size="0.04 0.04 0.03"/></geometry>
      <material name="orange"><color rgba="1.0 0.5 0.0 1"/></material>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- ==================== -->
  <!-- JOINTS               -->
  <!-- ==================== -->

  <joint name="arm_fl_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_fl"/>
    <origin xyz="0.15 0.15 0" rpy="0 0 0.785"/>
  </joint>

  <joint name="arm_fr_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_fr"/>
    <origin xyz="0.15 -0.15 0" rpy="0 0 -0.785"/>
  </joint>

  <joint name="arm_bl_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_bl"/>
    <origin xyz="-0.15 0.15 0" rpy="0 0 -0.785"/>
  </joint>

  <joint name="arm_br_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_br"/>
    <origin xyz="-0.15 -0.15 0" rpy="0 0 0.785"/>
  </joint>

  <joint name="rotor_fl_joint" type="continuous">
    <parent link="arm_fl"/>
    <child link="rotor_fl"/>
    <origin xyz="0.07 0.07 0.015" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="rotor_fr_joint" type="continuous">
    <parent link="arm_fr"/>
    <child link="rotor_fr"/>
    <origin xyz="0.07 -0.07 0.015" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="rotor_bl_joint" type="continuous">
    <parent link="arm_bl"/>
    <child link="rotor_bl"/>
    <origin xyz="-0.07 0.07 0.015" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="rotor_br_joint" type="continuous">
    <parent link="arm_br"/>
    <child link="rotor_br"/>
    <origin xyz="-0.07 -0.07 0.015" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="rgb_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rgb_camera_link"/>
    <origin xyz="0.1 0.0 -0.065" rpy="0 1.5707 0"/>
  </joint>

  <joint name="thermal_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="thermal_camera_link"/>
    <origin xyz="0.13 0.06 -0.065" rpy="0 1.5707 0"/>
  </joint>

  <!-- ==================== -->
  <!-- GAZEBO PLUGINS       -->
  <!-- ==================== -->

  <gazebo reference="base_link">
    <material>Gazebo/DarkGrey</material>
    <!-- Thermal signature — makes base_link warm -->
    <temperature>310.0</temperature>
  </gazebo>

  <gazebo reference="arm_fl"><material>Gazebo/Grey</material></gazebo>
  <gazebo reference="arm_fr"><material>Gazebo/Grey</material></gazebo>
  <gazebo reference="arm_bl"><material>Gazebo/Grey</material></gazebo>
  <gazebo reference="arm_br"><material>Gazebo/Grey</material></gazebo>
  <gazebo reference="rotor_fl"><material>Gazebo/Black</material></gazebo>
  <gazebo reference="rotor_fr"><material>Gazebo/Black</material></gazebo>
  <gazebo reference="rotor_bl"><material>Gazebo/Black</material></gazebo>
  <gazebo reference="rotor_br"><material>Gazebo/Black</material></gazebo>

  <!-- RGB Camera Sensor -->
  <gazebo reference="rgb_camera_link">
    <material>Gazebo/Red</material>
    <sensor name="rgb_camera" type="camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <camera>
        <horizontal_fov>1.3962634</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>300</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
      <topic>/trident/rgb/image_raw</topic>
    </sensor>
  </gazebo>

  <!-- Thermal Camera Sensor -->
  <gazebo reference="thermal_camera_link">
    <material>Gazebo/Orange</material>
    <sensor name="thermal_camera" type="thermal_camera">
      <always_on>true</always_on>
      <update_rate>15</update_rate>
      <visualize>true</visualize>
      <camera>
        <horizontal_fov>0.9599</horizontal_fov>
        <image>
          <width>320</width>
          <height>240</height>
          <format>L8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>100</far>
        </clip>
      </camera>
      <topic>/trident/thermal/image_raw</topic>
    </sensor>
  </gazebo>

</robot>