<?xml version="1.0"?>
<robot name="trident_drone">

  <!-- ==================== -->
  <!-- LINKS                -->
  <!-- ==================== -->

  <!-- Main body -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.3 0.3 0.1"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.3 0.3 0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0"
               iyy="0.01" iyz="0"
               izz="0.02"/>
    </inertial>
  </link>

  <!-- Arm Front-Left -->
  <link name="arm_fl">
    <visual>
      <geometry>
        <box size="0.15 0.03 0.02"/>
      </geometry>
      <material name="grey">
        <color rgba="0.4 0.4 0.4 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0"
               izz="0.001"/>
    </inertial>
  </link>

  <!-- Arm Front-Right -->
  <link name="arm_fr">
    <visual>
      <geometry>
        <box size="0.15 0.03 0.02"/>
      </geometry>
      <material name="grey">
        <color rgba="0.4 0.4 0.4 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0"
               izz="0.001"/>
    </inertial>
  </link>

  <!-- Arm Back-Left -->
  <link name="arm_bl">
    <visual>
      <geometry>
        <box size="0.15 0.03 0.02"/>
      </geometry>
      <material name="grey">
        <color rgba="0.4 0.4 0.4 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0"
               izz="0.001"/>
    </inertial>
  </link>

  <!-- Arm Back-Right -->
  <link name="arm_br">
    <visual>
      <geometry>
        <box size="0.15 0.03 0.02"/>
      </geometry>
      <material name="grey">
        <color rgba="0.4 0.4 0.4 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0"
               izz="0.001"/>
    </inertial>
  </link>

  <!-- Rotor Front-Left -->
  <link name="rotor_fl">
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.01"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0"
               izz="0.0002"/>
    </inertial>
  </link>

  <!-- Rotor Front-Right -->
  <link name="rotor_fr">
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.01"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0"
               izz="0.0002"/>
    </inertial>
  </link>

  <!-- Rotor Back-Left -->
  <link name="rotor_bl">
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.01"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0"
               izz="0.0002"/>
    </inertial>
  </link>

  <!-- Rotor Back-Right -->
  <link name="rotor_br">
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.01"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0"
               izz="0.0002"/>
    </inertial>
  </link>

  <!-- RGB Camera -->
  <link name="rgb_camera_link">
    <visual>
      <geometry>
        <box size="0.04 0.04 0.03"/>
      </geometry>
      <material name="red">
        <color rgba="0.8 0.1 0.1 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0"
               izz="0.0001"/>
    </inertial>
  </link>

  <!-- Thermal Camera -->
  <link name="thermal_camera_link">
    <visual>
      <geometry>
        <box size="0.04 0.04 0.03"/>
      </geometry>
      <material name="orange">
        <color rgba="1.0 0.5 0.0 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0"
               izz="0.0001"/>
    </inertial>
  </link>

  <!-- ==================== -->
  <!-- JOINTS               -->
  <!-- ==================== -->

  <joint name="arm_fl_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_fl"/>
    <origin xyz="0.15 0.15 0" rpy="0 0 0.785"/>
  </joint>

  <joint name="arm_fr_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_fr"/>
    <origin xyz="0.15 -0.15 0" rpy="0 0 -0.785"/>
  </joint>

  <joint name="arm_bl_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_bl"/>
    <origin xyz="-0.15 0.15 0" rpy="0 0 -0.785"/>
  </joint>

  <joint name="arm_br_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_br"/>
    <origin xyz="-0.15 -0.15 0" rpy="0 0 0.785"/>
  </joint>

  <joint name="rotor_fl_joint" type="continuous">
    <parent link="arm_fl"/>
    <child link="rotor_fl"/>
    <origin xyz="0.07 0.07 0.015" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="rotor_fr_joint" type="continuous">
    <parent link="arm_fr"/>
    <child link="rotor_fr"/>
    <origin xyz="0.07 -0.07 0.015" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="rotor_bl_joint" type="continuous">
    <parent link="arm_bl"/>
    <child link="rotor_bl"/>
    <origin xyz="-0.07 0.07 0.015" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="rotor_br_joint" type="continuous">
    <parent link="arm_br"/>
    <child link="rotor_br"/>
    <origin xyz="-0.07 -0.07 0.015" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Cameras mounted underneath, pointing down -->
  <!-- Matching your actual TRIDENT offsets -->
  <joint name="rgb_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rgb_camera_link"/>
    <origin xyz="0.1 0.0 -0.065" rpy="0 1.5707 0"/>
  </joint>

  <joint name="thermal_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="thermal_camera_link"/>
    <origin xyz="0.13 0.06 -0.065" rpy="0 1.5707 0"/>
  </joint>

  <!-- ==================== -->
  <!-- GAZEBO TAGS          -->
  <!-- ==================== -->

  <gazebo reference="base_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <gazebo reference="arm_fl">
    <material>Gazebo/Grey</material>
  </gazebo>

  <gazebo reference="arm_fr">
    <material>Gazebo/Grey</material>
  </gazebo>

  <gazebo reference="arm_bl">
    <material>Gazebo/Grey</material>
  </gazebo>

  <gazebo reference="arm_br">
    <material>Gazebo/Grey</material>
  </gazebo>

  <gazebo reference="rotor_fl">
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="rotor_fr">
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="rotor_bl">
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="rotor_br">
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="rgb_camera_link">
    <material>Gazebo/Red</material>
  </gazebo>

  <gazebo reference="thermal_camera_link">
    <material>Gazebo/Orange</material>
  </gazebo>

  <!-- RGB Camera Sensor -->
  <gazebo reference="rgb_camera_link">
    <sensor name="rgb_camera" type="camera">
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>50</far>
        </clip>
      </camera>
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <topic>rgb_camera/image</topic>
    </sensor>
  </gazebo>
  
  <!-- Thermal Camera Sensor -->
  <gazebo reference="thermal_camera_link">
    <sensor name="thermal_camera" type="thermal_camera">
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>L16</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>50</far>
        </clip>
      </camera>
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <topic>thermal_camera/image</topic>
    </sensor>
  </gazebo>

  <gazebo reference="base_link">
    <temperature>320</temperature>
  </gazebo>

</robot>